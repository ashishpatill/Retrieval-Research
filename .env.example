# ── API keys ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=ADD_YOUR_GEMINI_KEY
# Get free key: https://aistudio.google.com/app/apikey

# ── Storage ──────────────────────────────────────────────────────────────
RR_DATA_ROOT=data

# ── OCR / Ingestion ──────────────────────────────────────────────────────
GEMINI_MODEL=gemini-3.1-pro-preview
MLX_GLM_OCR_MODEL=mlx-community/GLM-OCR-6bit
OCR_MIN_DIM=1200
OCR_MAX_DIM=2400
RR_OCR_MODE=Hybrid
RR_DPI=150

# ── Chunking ─────────────────────────────────────────────────────────────
RR_CHUNK_MAX_WORDS=220
RR_CHUNK_OVERLAP_WORDS=40

# ── BM25 ─────────────────────────────────────────────────────────────────
RR_BM25_K1=1.5
RR_BM25_B=0.75

# ── Dense ────────────────────────────────────────────────────────────────
RR_DENSE_DIMENSIONS=384

# ── Late interaction ─────────────────────────────────────────────────────
RR_LATE_DIMENSIONS=128
RR_LATE_MAX_DOC_TOKENS=256

# ── Visual ───────────────────────────────────────────────────────────────
RR_VISUAL_DIMENSIONS=384
RR_VISUAL_BACKEND=baseline
RR_VISUAL_COMPRESSION=none

# ── ColPali ──────────────────────────────────────────────────────────────
RR_COLPALI_MODEL=vidore/colpali-v1.2
RR_DEVICE=auto

# ── Retrieval ────────────────────────────────────────────────────────────
RR_TOP_K=5
RR_RETRIEVAL_MODE=planner
RR_PLANNER_MERGE_STRATEGY=score_max
RR_PLANNER_RERANK=true
RR_ROUTE_VOTE_BONUS=0.08
RR_RERANK_OVERLAP_WEIGHT=0.10
